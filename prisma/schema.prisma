generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("db_DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  age           Int?
  gender        String?
  phone         String?
  registrations Registration[]
}

model Event {
  id            String         @id @default(cuid())
  title         String
  description   String
  includes      String
  date          DateTime
  createdAt     DateTime       @default(now())
  price         Int            @default(0)
  slug          String         @unique
  updatedAt     DateTime       @updatedAt
  status        Status         @default(DRAFT)
  registrations Registration[]
}

model Registration {
  id                String   @id @default(cuid())
  userId            String
  eventId           String
  paymentReceiptUrl String?
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  qualification     String   @default("UMUM")
  event             Event    @relation(fields: [eventId], references: [id])
  user              User     @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum Status {
  DRAFT
  PUBLISHED
  ARCHIVED
}
